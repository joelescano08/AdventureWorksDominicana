@page "/MyAccount"

@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@using AdventureWorksDominicana.Data.Models
@inject AuthenticationStateProvider authenticationStateProvider
@inject ToastService toastService
@inject PhoneNumberTypeService phoneNumberTypeService
@inject PersonService personService
@inject NavigationManager navigationManager
@rendermode InteractiveServer

<EditForm Model="Modelo" OnValidSubmit="GuardarCambios">
    <DataAnnotationsValidator />

    <div class="account-container">
        <div class="account-header">
            <div>
                <h2>Mi Cuenta</h2>
                <p>Gestiona tu información personal y métodos de contacto.</p>
                @if (datosSinGuardar)
                {
                    <div class="account-alert mt-2">
                        <i class="bi bi-exclamation-triangle"></i> Hay cambios importantes sin guardar.
                    </div>
                }
            </div>
            <div>
                <button type="submit" class="btn-account-primary">
                    <i class="bi bi-floppy"></i> Guardar Cambios
                </button>
            </div>
         
        </div>

        <div class="row">
            <div class="col-lg-5 mb-4">
                <div class="account-card h-100">
                    <div class="card-body">
                        <h4 class="account-section-title">
                            <i class="bi bi-person-circle"></i> Información Personal
                        </h4>

                        <div class="mb-3">
                            <label class="account-form-label">Nombre</label>
                            <input type="text" class="account-form-control bg-light" @bind="Modelo.FirstName" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="account-form-label">Segundo Nombre</label>
                            <input type="text" class="account-form-control" @bind="Modelo.MiddleName" placeholder="Opcional" />
                        </div>

                        <div class="mb-3">
                            <label class="account-form-label">Apellido</label>
                            <input type="text" class="account-form-control bg-light" @bind="Modelo.LastName" readonly />
                        </div>

                        <hr class="account-divider" />

                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="promoSwitch" @bind="Modelo.WantsPromotions">
                            <label class="form-check-label" for="promoSwitch">
                                Deseo recibir correos promocionales y ofertas
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <!-- CORREOS ELECTRÓNICOS -->
                <div class="account-card mb-4">
                    <div class="card-body">
                        <div class="account-header-with-button">
                            <h5 class="account-section-title mb-0">
                                <i class="bi bi-envelope"></i> Correos Electrónicos
                            </h5>
                            <button type="button" class="btn-account-outline" @onclick="AgregarCorreo">
                                <i class="bi bi-plus-lg"></i> Agregar Correo
                            </button>
                        </div>

                        <div class="mb-4">
                            <label class="account-form-label">Correo de Acceso (Principal)</label>
                            <input type="text" class="account-form-control bg-light" value="@UserEmail" readonly />
                        </div>

                        <hr class="account-divider" />

                        @foreach (var email in Modelo.Emails)
                        {
                            <div class="account-item-row">
                                <div class="account-item-field">
                                    <input type="email" class="account-form-control" @bind="email.EmailAddress1" placeholder="ejemplo@correo.com" />
                                    <ValidationMessage For="@(() => email.EmailAddress1)" class="text-danger small" />
                                </div>
                                <div class="account-item-actions">
                                    <button type="button" class="btn-account-danger" @onclick="() => EliminarCorreo(email)">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="account-empty-state">
                                <i class="bi bi-envelope"></i>
                                <p>No tienes correos alternativos registrados.</p>
                            </div>
                        }

                        @if (Modelo.NuevoCorreo != null)
                        {
                            <div class="row g-2 p-3 border rounded bg-light position-relative">
                                <div class="col-12 d-flex justify-content-between align-items-center mb-2">
                                    <span class="small fw-semibold text-primary">Registrar Nuevo Correo</span>
                                    <button type="button" class="btn-close" aria-label="Close" @onclick="CancelarNuevoCorreo"></button>
                                </div>
                                <div class="col-12">
                                    <input type="email" class="form-control" @bind="Modelo.NuevoCorreo.EmailAddress1" placeholder="ejemplo@correo.com" />
                                    <ValidationMessage For="@(() => Modelo.NuevoCorreo.EmailAddress1)" class="text-danger small" />
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- TELÉFONOS -->
                <div class="account-card mb-4">
                    <div class="card-body">
                        <div class="account-header-with-button">
                            <h5 class="account-section-title mb-0">
                                <i class="bi bi-telephone"></i> Números de Teléfono
                            </h5>
                            <button type="button" class="btn-account-outline" @onclick="AgregarTelefono">
                                <i class="bi bi-plus-lg"></i> Agregar Teléfono
                            </button>
                        </div>

                        @foreach (var phone in Modelo.Phones)
                        {
                            <div class="account-item-row">
                                <div class="account-item-field">
                                    <input type="text" class="account-form-control" @bind="phone.PhoneNumber" placeholder="Ej: 809-555-5555" />
                                    <ValidationMessage For="@(() => phone.PhoneNumber)" class="text-danger small" />
                                </div>
                                <div class="account-item-field">
                                    <select class="account-form-control" @bind="phone.PhoneNumberTypeId">
                                        @foreach (var tipo in ListaTiposTelefono)
                                        {
                                            <option value="@tipo.PhoneNumberTypeId">@tipo.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="account-item-actions">
                                    <button type="button" class="btn-account-danger" @onclick="() => EliminarTelefono(phone)">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                </div>
                            </div>
                        }
                        @if (!Modelo.Phones.Any())
                        {
                            <div class="account-empty-state">
                                <i class="bi bi-telephone"></i>
                                <p>No hay teléfonos registrados.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</EditForm>

@code {
    private ClaimsPrincipal? User { get; set; }
    private bool IsAuthenticated { get; set; }
    private string? UserEmail { get; set; }
    private string UserId { get; set; } = string.Empty;
    private int _businessEntityId = 0;

    private List<PhoneNumberType> ListaTiposTelefono { get; set; } = new();

    private bool datosSinGuardar = false;

    private AccountViewModel Modelo { get; set; } = new();

    public class AccountViewModel
    {
        public string FirstName { get; set; } = string.Empty;
        public string MiddleName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public bool WantsPromotions { get; set; }

        public List<EmailAddress> Emails { get; set; } = new();
        public EmailAddress? NuevoCorreo { get; set; }

        public List<PersonPhone> Phones { get; set; } = new();
        public PersonPhone? NuevoTelefono { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        ListaTiposTelefono = await phoneNumberTypeService.GetList(x => true);

        var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
        User = authState.User;
        IsAuthenticated = User.Identity?.IsAuthenticated ?? false;

        if (IsAuthenticated)
        {
            UserEmail = User.FindFirst(ClaimTypes.Email)?.Value;
            var idClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(idClaim) && !string.IsNullOrEmpty(UserEmail))
            {
                UserId = idClaim;
                await CargarDatosDelUsuario(UserEmail);
            }
            else
            {
                toastService.ShowError("No se pudo identificar al usuario.");
            }
        }
    }

    private async Task CargarDatosDelUsuario(string email)
    {
        var personaDB = await personService.BuscarPorEmailCompleto(email);

        if (personaDB != null)
        {
            _businessEntityId = personaDB.BusinessEntityId;
            Modelo.FirstName = personaDB.FirstName;
            Modelo.MiddleName = personaDB.MiddleName ?? string.Empty;
            Modelo.LastName = personaDB.LastName;
            Modelo.WantsPromotions = personaDB.EmailPromotion > 0;

            if (personaDB.EmailAddresses != null)
            {
                Modelo.Emails = personaDB.EmailAddresses
                    .Where(e => e.EmailAddress1 != email)
                    .Select(e => new EmailAddress { EmailAddress1 = e.EmailAddress1 })
                    .ToList();
            }

            if (personaDB.PersonPhones != null)
            {
                Modelo.Phones = personaDB.PersonPhones
                    .Select(p => new PersonPhone
                    {
                        PhoneNumber = p.PhoneNumber,
                        PhoneNumberTypeId = p.PhoneNumberTypeId
                    })
                    .ToList();
            }
        }
        else
        {
            toastService.ShowWarning("No encontramos tu perfil en el sistema. Completa tus datos.");
        }
    }

    // Lógica para Correos
    private void AgregarCorreo() { Modelo.NuevoCorreo = new EmailAddress(); datosSinGuardar = true; }
    private void CancelarNuevoCorreo() { Modelo.NuevoCorreo = null; if (Modelo.NuevoTelefono == null) datosSinGuardar = false; }
    private void EliminarCorreo(EmailAddress item) { Modelo.Emails.Remove(item); datosSinGuardar = true; toastService.ShowWarning("Correo listo para eliminar. Para abortar pulsa cancelar cambios."); }

    // Lógica para Teléfonos
    private void AgregarTelefono()
    {
        int defaultType = ListaTiposTelefono.FirstOrDefault()?.PhoneNumberTypeId ?? 1;
        Modelo.NuevoTelefono = new PersonPhone { PhoneNumberTypeId = defaultType };
        datosSinGuardar = true;
    }
    private void CancelarNuevoTelefono() { Modelo.NuevoTelefono = null; if (Modelo.NuevoCorreo == null) datosSinGuardar = false; }
    private void EliminarTelefono(PersonPhone item) { Modelo.Phones.Remove(item); datosSinGuardar = true; toastService.ShowWarning("Teléfono listo para eliminar. Para abortar pulsa cancelar cambios."); }

    // Método auxiliar para la UI
    private string ObtenerNombreTipoTelefono(int typeId)
    {
        return ListaTiposTelefono.FirstOrDefault(t => t.PhoneNumberTypeId == typeId)?.Name ?? "Desconocido";
    }

    private async Task GuardarCambios()
    {
        if (_businessEntityId == 0)
        {
            toastService.ShowWarning("Aún no tienes un perfil base.");
            return;
        }

        // Validar el nuevo correo si el usuario está intentando agregar uno
        if (Modelo.NuevoCorreo != null && !string.IsNullOrWhiteSpace(Modelo.NuevoCorreo.EmailAddress1))
        {
            var context = new ValidationContext(Modelo.NuevoCorreo);
            var results = new List<ValidationResult>();
            if (!Validator.TryValidateObject(Modelo.NuevoCorreo, context, results, true))
            {
                var error = results.FirstOrDefault()?.ErrorMessage ?? "Error en el formato del nuevo correo.";
                toastService.ShowError(error);
                return;
            }
        }

        // Validar el nuevo teléfono 
        if (Modelo.NuevoTelefono != null && !string.IsNullOrWhiteSpace(Modelo.NuevoTelefono.PhoneNumber))
        {
            var context = new ValidationContext(Modelo.NuevoTelefono);
            var results = new List<ValidationResult>();
            if (!Validator.TryValidateObject(Modelo.NuevoTelefono, context, results, true))
            {
                var error = results.FirstOrDefault()?.ErrorMessage ?? "Error en el formato del nuevo teléfono.";
                toastService.ShowError(error);
                return;
            }
        }

        var personaActualizada = new Person
        {
            FirstName = Modelo.FirstName,
            MiddleName = string.IsNullOrWhiteSpace(Modelo.MiddleName) ? null : Modelo.MiddleName,
            LastName = Modelo.LastName,
            EmailPromotion = Modelo.WantsPromotions ? 1 : 0
        };

        // CORREO PRINCIPAL
        if (!string.IsNullOrEmpty(UserEmail))
        {
            personaActualizada.EmailAddresses.Add(new EmailAddress { EmailAddress1 = UserEmail });
        }

        // CORREOS ALTERNATIVOS EXISTENTES
        foreach (var email in Modelo.Emails)
        {
            personaActualizada.EmailAddresses.Add(new EmailAddress { EmailAddress1 = email.EmailAddress1 });
        }

        // NUEVO CORREO (Si pasó validación)
        if (Modelo.NuevoCorreo != null && !string.IsNullOrWhiteSpace(Modelo.NuevoCorreo.EmailAddress1))
        {
            personaActualizada.EmailAddresses.Add(new EmailAddress { EmailAddress1 = Modelo.NuevoCorreo.EmailAddress1 });
        }

        // TELÉFONOS EXISTENTES
        foreach (var phone in Modelo.Phones)
        {
            personaActualizada.PersonPhones.Add(new PersonPhone
            {
                PhoneNumber = phone.PhoneNumber,
                PhoneNumberTypeId = phone.PhoneNumberTypeId
            });
        }

        // NUEVO TELÉFONO (Si pasó validación)
        if (Modelo.NuevoTelefono != null && !string.IsNullOrWhiteSpace(Modelo.NuevoTelefono.PhoneNumber))
        {
            personaActualizada.PersonPhones.Add(new PersonPhone
            {
                PhoneNumber = Modelo.NuevoTelefono.PhoneNumber,
                PhoneNumberTypeId = Modelo.NuevoTelefono.PhoneNumberTypeId
            });
        }

        var exito = await personService.ActualizarPerfilCompleto(_businessEntityId, personaActualizada);

        if (exito)
        {
            toastService.ShowSuccess("Tus cambios han sido guardados correctamente.");
            datosSinGuardar = false;
            
            // oculto los mini-formularios tras guardar exitosamente
            Modelo.NuevoCorreo = null;
            Modelo.NuevoTelefono = null;

            // se recatgan los datos para que los nuevos elementos pasen a las listas oficiales
            await CargarDatosDelUsuario(UserEmail!);
        }
        else
        {
            toastService.ShowError("Ocurrió un error al intentar guardar los cambios.");
        }
    }
}