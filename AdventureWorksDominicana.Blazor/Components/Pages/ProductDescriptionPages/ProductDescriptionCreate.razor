@page "/ProductDescription/Create"

@inject ProductDescriptionService productDescriptionService;
@inject ToastService toastService;
@inject NavigationManager navigationManager;
@rendermode InteractiveServer

<EditForm Model="ProductDesc" FormName="crearDesc" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />

    <div class="container pb-5">
        <div class="card shadow-lg">
            <div class="card-header text-center">
                <h4>Nuevo Texto Descriptivo</h4>
            </div>
            <div class="card-body">
                
                <h5 class="pb-3 text-primary border-bottom">Contenido Comercial</h5>
                
                <div class="mb-3">
                    <label><strong>Párrafo de Descripción *</strong></label>
                    <textarea class="form-control" rows="5" maxlength="400" @bind="ProductDesc.Description" placeholder="Ej: Bicicleta de alto rendimiento diseñada para recorridos de montaña extremo..."></textarea>
                    <ValidationMessage For="(() => ProductDesc.Description)" />
                    <small class="text-muted">Evita mencionar colores o tamaños específicos, redacta pensando en la línea general del modelo.</small>
                </div>

            </div>
            <div class="card-footer text-center">
                <a class="btn btn-secondary bi bi-arrow-left" href="/ProductDescription/Index"> Volver</a>
                <button class="btn btn-primary bi bi-floppy" type="submit"> Guardar Registro</button>
            </div>
        </div>
    </div>
</EditForm>

@code {
    public ProductDescription ProductDesc { get; set; } = new ProductDescription();

    public async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(ProductDesc.Description))
        {
            toastService.ShowWarning("La descripción no puede estar vacía.");
            return;
        }

        var existeDuplicado = await productDescriptionService.GetList(d => d.Description.ToLower().Trim() == ProductDesc.Description.ToLower().Trim());
        if (existeDuplicado.Any())
        {
            toastService.ShowWarning("Esta descripción exacta ya existe en el sistema.");
            return;
        }

        bool guardado = await productDescriptionService.Guardar(ProductDesc);
        if (guardado)
        {
            toastService.ShowSuccess("Descripción registrada correctamente en el banco de textos.");
            navigationManager.NavigateTo("/ProductDescription/Index");
        }
        else
        {
            toastService.ShowError("Ha ocurrido un error inesperado al guardar.");
        }
    }
}
