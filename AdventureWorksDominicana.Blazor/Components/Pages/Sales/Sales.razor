@page "/Sales"

@attribute [Authorize(Roles = "Customer, Admin, SalesManager")]
@rendermode InteractiveServer
@inject ProductInventoryService productInventoryService
@inject ShoppingCartItemService shoppingCartItemService
@inject ToastService toastService
@inject NavigationManager navigationManager
@inject AuthenticationStateProvider authenticationStateProvider;

<PageTitle>SalesOrderHeader Index</PageTitle>
<div class="">
    <div class="sale-container">
        @*Header*@
        <div class="sale-topbar">

            <div class="sale-topbar-left">
                <h5>Tienda</h5>
                <span>Explora productos disponibles</span>
            </div>

            <div class="sale-topbar-right">
                <a href="Orders" class="btn-outline">
                    <i class="bi bi-bag"></i> Mis pedidos
                </a>

                <a href="ShoppingCart" class="btn-primary shopping-cart-container">
                    <i class="bi bi-cart"></i>
                    <span>@shoppingCount</span>
                </a>
            </div>

        </div>
        <div class="card-body">
            @*Filters*@
            <div class="sale-input">
                <div class="input-group">
                    <input class="form-control" placeholder="Buscar producto..." @oninput="Buscar" />
                    <i class="btn btn-primary bi bi-search"></i>
                </div>
                <div class="input-group">
                    <select class="form-select">
                        <option value="" hidden selected disabled>Por Categoria</option>
                    </select>
                    <i class="btn btn-primary bi bi-filter"></i>
                </div>
            </div>
            @*Product List*@
            <div class="sale-products">
                @foreach (var p in PagedProducts)
                {
                    <div class="sale-product-card">
                        <div class="sale-product-img">
                            @{
                                // EXPLICACIÓN 1: Extraemos el brazo relacionador que marca la imagen como "True" (Primaria)
                                var nexoFoto = p.Product.ProductProductPhotos.FirstOrDefault(f => f.Primary == true);
                                
                                // EXPLICACIÓN 2: Esto es un Fallback. Si el producto recién creado no se le subió foto, mostramos el gris
                                string imgUrl = "https://www.svgrepo.com/show/486796/product-management.svg";
                                
                                // EXPLICACIÓN 3: Si sí hay foto binaria cargada en la BD, la convertimos a lenguaje Web (Base64)
                                if (nexoFoto != null && nexoFoto.ProductPhoto?.ThumbNailPhoto != null)
                                {
                                    var base64 = Convert.ToBase64String(nexoFoto.ProductPhoto.ThumbNailPhoto);
                                    imgUrl = $"data:image/jpeg;base64,{base64}";
                                }
                            }
                            <img src="@imgUrl" alt="@p.Product.Name" style="object-fit: cover; width: 100%; height: 100%; border-radius: 8px;" />
                            
                            @if (!string.IsNullOrWhiteSpace(p.Product.Color))
                            {
                                <span>@p.Product.Color</span>
                            }
                        </div>
                        
                        <div class="sale-product-info">
                            <span>@(p.Product?.ProductSubcategory?.ProductCategory?.Name ?? "N/A")</span>
                            <div class="sale-product-name">
                                <p>@p.Product?.Name</p>
                            </div>
                            <div class="sale-product-description">
                                <p>@(p.Product?.ProductModel?.ProductModelProductDescriptionCultures.FirstOrDefault()?.ProductDescription?.Description ?? "N/A")</p>
                            </div>
                            <div class="sale-product-price">
                                <span>RD$ @p.Product?.ListPrice.ToString("N2")</span>
                            </div>
                            <button type="button" @onclick="() => Guardar(p.ProductId)">
                                <i class="bi bi-cart"></i>
                                <span>Añadir al Carrito</span>
                            </button>
                        </div>
                    </div>
                }
            </div>
            <div class="pagination">
                <i class="bi bi-arrow-left" @onclick="PaginaAnterior"></i>
                <span>@CurrentPage</span>
                <span>/</span>
                <span>@TotalPaginas</span>
                <i class="bi bi-arrow-right" @onclick="PaginaSiguiente"></i>
            </div>
        </div>
    </div>
</div>
@code {
    private List<ProductInventory> ProductList = new List<ProductInventory>();
    private List<ProductInventory> PagedProducts = new List<ProductInventory>();

    private string Filtro = string.Empty, ValorFiltro = string.Empty;
    private string? UserEmail { get; set; }

    private int shoppingCount = 0;
    private int CurrentPage = 1;
    private int PageSize = 12;
    private int TotalPaginas => (int)Math.Ceiling((double)ProductList.Count / PageSize);

    private ClaimsPrincipal? User { get; set; }
    private bool IsAuthenticated { get; set; }


    protected override async Task OnInitializedAsync()
    {
        // Busca el usuario logeado
        var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
        User = authState.User;
        IsAuthenticated = User.Identity?.IsAuthenticated ?? false;
        if (IsAuthenticated)
            UserEmail = User.FindFirst(ClaimTypes.Email)?.Value;
        ProductList = await productInventoryService.GetList(p => p.Quantity > 0);
        ActualizarVista();
        await CountProductsShopping();
    }

    private async Task GoToProductDetail(int id) => navigationManager.NavigateTo("/Product/Detail/" + id);

    private async Task CountProductsShopping()
    {
        var productsShoppingList = await shoppingCartItemService.GetList(s => s.ShoppingCartId.Trim().ToLower().Equals(UserEmail));
        shoppingCount = productsShoppingList.Count();
    }

    private async Task Guardar(int productId)
    {
        try
        {
            if (UserEmail == null) return;
            var creado = await shoppingCartItemService.Guardar(
            new ShoppingCartItem
            {
                ShoppingCartId = UserEmail,
                Quantity = 1,
                ProductId = productId,
                DateCreated = DateTime.Now,
                ModifiedDate = DateTime.Now
            });
            toastService.ShowSuccess("Producto añadido al carrito");
            await CountProductsShopping();
        }
        catch(InvalidOperationException ex)
        {
            toastService.ShowWarning(ex.Message);
        }
        catch (Exception ex)
        {
            toastService.ShowError("Producto no pudo ser añadido al carrito");
            Console.WriteLine(ex.Message);
        }
    }

    private void ActualizarVista()
    {
        PagedProducts = ProductList
            .Skip((CurrentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();
    }

    private void PaginaSiguiente()
    {
        if (CurrentPage < TotalPaginas)
        {
            CurrentPage++;
            ActualizarVista();
        }
    }

    private void PaginaAnterior()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
            ActualizarVista();
        }
    }

    private async Task Buscar(ChangeEventArgs e)
    {
        var value = e?.Value?.ToString();
        Expression<Func<Product, bool>> criterio = e => true;
        if (value?.Trim() != "" && value != null)
            criterio = criterio.And(e => e.Name.Contains(value) || (e.ProductSubcategory != null && e.ProductSubcategory.ProductCategory != null && e.ProductSubcategory.ProductCategory.Name.Contains(value)));

        ActualizarVista();
    }
}