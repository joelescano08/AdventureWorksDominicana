@page "/Product/Inventory"
@attribute [Authorize(Roles = "Admin, ProductionManager, SalesManager")]

@rendermode InteractiveServer
@using AdventureWorksDominicana.Services
@using AdventureWorksDominicana.Data.Models
@using InventoryModel = AdventureWorksDominicana.Data.Models.ProductInventory

@inject ProductInventoryService InventoryService

<PageTitle>Inventario de Bodegas</PageTitle>

<div class="inventory-container">

    <!-- HEADER -->
    <div class="inventory-header">
        <div>
            <h3>Control de Almacén</h3>
            <span>Existencias físicas por ubicación</span>
        </div>

        <AuthorizeView Roles="Admin, ProductionManager">
            <Authorized>
                <a href="/Product/InventoryEntry" class="btn btn-primary">
                    <i class="bi bi-box-arrow-in-right"></i> Dar Entrada
                </a>
            </Authorized>
        </AuthorizeView>
    </div>

    <!-- BUSCADOR -->
    <div class="inventory-filters">
        <div class="search-box">
            <input type="search"
                   placeholder="Buscar producto por nombre..."
                   @bind="Filtro"
                   @bind:event="oninput" />
            <i class="bi bi-search"></i>
        </div>
    </div>

    <!-- TABLA -->
    <div class="table-responsive inventory-table">

        <QuickGrid Items="@FilteredInventory"
                   Pagination="@pagination"
                   Class="table table-hover">

            <!-- PRODUCTO -->
            <TemplateColumn Title="Producto">
                <div class="product-info">
                    <strong>@(context.Product?.Name ?? "Sin Nombre")</strong>

                    <div class="product-meta">
                        <span>Estante @context.Shelf</span>
                        <span>Bin @context.Bin</span>
                    </div>
                </div>
            </TemplateColumn>

            <!-- UBICACIÓN -->
            <TemplateColumn Title="Ubicación">
                @(context.Location?.Name ?? "N/A")
            </TemplateColumn>

            <!-- CANTIDAD -->
            <PropertyColumn Property="@(p => p.Quantity)"
                            Title="Cantidad" />

            <!-- ESTADO -->
            <TemplateColumn Title="Estado">
                @if (context.Quantity <= (context.Product?.SafetyStockLevel ?? 0))
                {
                    <span class="badge danger">Stock Bajo</span>
                }
                else
                {
                    <span class="badge success">Stock Adecuado</span>
                }
            </TemplateColumn>

            <!-- AJUSTE -->
            
            <TemplateColumn Title="Ajuste" Class="text-center" Context="producto">
                <div class="adjust-buttons">

                    <button class="btn-adjust minus"
                            @onclick="() => Ajustar(producto, -1)"
                            disabled="@(producto.Quantity <= 0)">
                        <i class="bi bi-dash"></i>
                    </button>

                    <button class="btn-adjust plus"
                            @onclick="() => Ajustar(producto, 1)">
                        <i class="bi bi-plus"></i>
                    </button>

                </div>
            </TemplateColumn>
               

        </QuickGrid>

        <Paginator State="@pagination" />

    </div>
</div>

@code {
    private List<InventoryModel>? inventario;
    private string Filtro = string.Empty;
    private PaginationState pagination = new PaginationState { ItemsPerPage = 10 };

    protected override async Task OnInitializedAsync() => await CargarDatos();

    private async Task CargarDatos() => inventario = await InventoryService.GetList(i => true);

    private IQueryable<InventoryModel> FilteredInventory
    {
        get
        {
            var query = inventario?.AsQueryable() ?? Enumerable.Empty<InventoryModel>().AsQueryable();
            if (!string.IsNullOrWhiteSpace(Filtro))
            {
                query = query.Where(x => x.Product != null && x.Product.Name.Contains(Filtro, StringComparison.OrdinalIgnoreCase));
            }
            return query;
        }
    }

    private async Task Ajustar(InventoryModel item, short cantidad)
    {
        if (cantidad < 0 && item.Quantity <= 0) return;
        if (await InventoryService.AjustarExistencia(item.ProductId, item.LocationId, cantidad))
        {
            item.Quantity = (short)(item.Quantity + cantidad);
            StateHasChanged();
        }
    }
}