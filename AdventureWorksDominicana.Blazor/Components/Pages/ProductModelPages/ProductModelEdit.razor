@page "/ProductModel/Edit/{ModelId:int}"

@inject ProductModelService modelService;
@inject ProductDescriptionService descriptionService;
@inject CultureService cultureService;
@inject ToastService toastService;
@inject NavigationManager navigationManager;
@rendermode InteractiveServer

<EditForm Model="Model" FormName="editarModel" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />

    <div class="container pb-5">
        <div class="card shadow-lg">
            <div class="card-header text-center">
                <h4>Modificar Modelo y Textos</h4>
            </div>
            <div class="card-body">
                <h5 class="pb-3 text-primary border-bottom">Datos Técnicos del Modelo</h5>
                
                <div class="row">
                    <div class="col-md-2 mb-3">
                        <label><strong>ID Modelo</strong></label>
                        <input class="form-control" type="text" value="@Model.ProductModelId" disabled />
                    </div>
                    <div class="col-md-10 mb-3">
                        <label><strong>Nombre General de la Familia *</strong></label>
                        <input class="form-control" type="text" maxlength="50" @bind="Model.Name" />
                        <ValidationMessage For="(() => Model.Name)" />
                    </div>
                </div>

                <div class="border border-success rounded p-3 my-4 bg-light">
                    <h5 class="mb-3 text-success">Textos Descriptivos (Multilingüe/Ventas)</h5>
                    <div class="row mb-3 align-items-end">
                        <div class="col-md-3">
                            <label class="fw-bold text-muted small">Cultura/Idioma</label>
                            <select class="form-select" @bind="idCulturaSel">
                                <option value="" selected disabled>Seleccione...</option>
                                @foreach (var cult in ListaCulturas)
                                {
                                    <option value="@cult.CultureId">@cult.Name (@cult.CultureId)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-7">
                            <label class="fw-bold text-muted small">Seleccionar Párrafo Disponible</label>
                            <select class="form-select" @bind="idDescSel">
                                <option value="0" selected disabled>Escoge una descripción del banco...</option>
                                @foreach (var desc in ListaDescripciones)
                                {
                                    <option value="@desc.ProductDescriptionId">@desc.Description</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-success w-100 bi bi-plus-circle" @onclick="VincularTexto"> Añadir</button>
                        </div>
                    </div>

                    <div class="table-responsive bg-white rounded border">
                        <table class="table table-hover table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Cód. Idioma</th>
                                    <th>Texto Asignado</th>
                                    <th class="text-center">Quitar</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.ProductModelProductDescriptionCultures.Count == 0)
                                {
                                    <tr><td colspan="3" class="text-center text-muted">Sin descripciones asignadas</td></tr>
                                }
                                @foreach (var item in Model.ProductModelProductDescriptionCultures)
                                {
                                    <tr>
                                        <td><span class="badge bg-secondary">@item.CultureId</span></td>
                                        @if (item.ProductDescription != null)
                                        {
                                            <td><small>@item.ProductDescription.Description</small></td>
                                        }
                                        else
                                        {
                                            <td><small>Texto ID: @item.ProductDescriptionId (Nueva asignación)</small></td>
                                        }
                                        <td class="text-center">
                                            <button type="button" class="btn btn-outline-danger btn-sm bi bi-x-circle" @onclick="(() => DesvincularTexto(item))"></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                
                <h5 class="py-3 text-primary border-bottom">Documentación Extra</h5>
                <div class="mb-3">
                    <label><strong>Catálogo Técnico (XML)</strong></label>
                    <textarea class="form-control" rows="2" @bind="Model.CatalogDescription"></textarea>
                </div>
                <div class="mb-3">
                    <label><strong>Instrucciones Fab. (XML)</strong></label>
                    <textarea class="form-control" rows="2" @bind="Model.Instructions"></textarea>
                </div>

            </div>
            <div class="card-footer text-center">
                <a class="btn btn-secondary bi bi-arrow-left" href="/ProductModel/Index"> Volver</a>
                <button class="btn btn-primary bi bi-floppy" type="submit"> Consolidar Cambios</button>
            </div>
        </div>
    </div>
</EditForm>

@code {
    [Parameter]
    public int ModelId { get; set; }

    public ProductModel Model { get; set; } = new ProductModel();
    
    public List<ProductDescription> ListaDescripciones { get; set; } = new();
    public List<Culture> ListaCulturas { get; set; } = new();

    private string idCulturaSel = "";
    private int idDescSel = 0;

    protected override async Task OnInitializedAsync()
    {
        var modelEncontrado = await modelService.Buscar(ModelId);
        if (modelEncontrado == null)
        {
            toastService.ShowError("No se pudo encontrar el modelo.");
            navigationManager.NavigateTo("/ProductModel/Index");
            return;
        }
        Model = modelEncontrado;

        ListaDescripciones = await descriptionService.GetList(d => true);
        ListaCulturas = await cultureService.GetList(c => true);
    }

    private void VincularTexto()
    {
        if (string.IsNullOrEmpty(idCulturaSel) || idDescSel == 0)
        {
            toastService.ShowWarning("Debes seleccionar un idioma y una descripción.");
            return;
        }

        if (Model.ProductModelProductDescriptionCultures.Any(x => x.CultureId == idCulturaSel))
        {
            toastService.ShowWarning($"Ya existe una descripción asignada para el idioma '{idCulturaSel}'.");
            return;
        }

        Model.ProductModelProductDescriptionCultures.Add(new ProductModelProductDescriptionCulture
        {
            CultureId = idCulturaSel,
            ProductDescriptionId = idDescSel,
            ProductModelId = Model.ProductModelId
        });
        toastService.ShowSuccess("Párrafo asociado a la tabla temporal. No olvides guardar.");
        idCulturaSel = ""; idDescSel = 0;
    }
    private void DesvincularTexto(ProductModelProductDescriptionCulture item)
    {
        Model.ProductModelProductDescriptionCultures.Remove(item);
    }

    public async Task Guardar()
    {
        bool guardado = await modelService.Guardar(Model);
        if (guardado)
        {
            toastService.ShowSuccess("El modelo multilingüe se consolidó correctamente.");
            navigationManager.NavigateTo("/ProductModel/Index");
        }
        else
        {
            toastService.ShowError("Ha ocurrido un error al intentar vincular los datos.");
        }
    }
}
